{
  "name": "@oraclepersonal/oracle",
  "version": "0.3.0",
  "description": "Oracle Assistant — an MCP-powered AI assistant with persistent memory, a knowledge base, web access, and an inter-agent message bus for Claude Code, opencode, and other coding agents.",
  "keywords": [
    "oracle-assistant",
    "mcp",
    "mcp-server",
    "ai-assistant",
    "ai-coding-assistant",
    "claude-code",
    "opencode",
    "llm-tools",
    "code-review-cli",
    "agent-memory",
    "inter-agent-messaging",
    "multi-agent"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OraclePersonal/Oracle.git"
  },
  "homepage": "https://github.com/OraclePersonal/Oracle#readme",
  "bugs": {
    "url": "https://github.com/OraclePersonal/Oracle/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "oracle": "./dist/cli.js",
    "oracle-daemon": "./dist/daemon.js",
    "oracle-mcp": "./dist/mcp.js",
    "oracle-msg-mcp": "./dist/mcp-messaging.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "docs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "daemon": "tsx src/daemon.ts",
    "mcp": "tsx src/mcp.ts",
    "mcp:messaging": "tsx src/mcp-messaging.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src",
    "test:cli": "node scripts/smoke-cli.mjs",
    "test:runtime": "node scripts/smoke-runtime.mjs",
    "verify": "npm run build && npm run test && npm run test:cli && npm run test:runtime",
    "prepublishOnly": "npm run verify"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node-cron": "^3.0.11",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "node-cron": "^3.0.3",
    "openai": "^6.45.0",
    "readdown": "^0.2.5",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
