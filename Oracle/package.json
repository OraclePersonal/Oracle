{
  "name": "oracle",
  "version": "0.0.2",
  "description": "Oracle Assistant — an MCP-powered AI assistant with persistent memory, a knowledge base, and web access for Claude Code, opencode, and other coding agents.",
  "keywords": [
    "oracle-assistant",
    "mcp",
    "mcp-server",
    "ai-assistant",
    "ai-coding-assistant",
    "claude-code",
    "opencode",
    "llm-tools",
    "code-review-cli",
    "agent-memory"
  ],
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "oracle": "./dist/cli.js",
    "oracle-mcp": "./dist/mcp.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "mcp": "tsx src/mcp.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "openai": "^6.45.0",
    "readdown": "^0.2.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
